erDiagram
    AwsScan {
        string scan_id PK
        string region
        datetime timestamp
        int ec2_count
        int s3_count
        int iam_user_count
        int sg_count
        int vpc_count
    }

    SecurityFinding {
        string finding_id PK
        string scan_id FK
        string resource_id
        string resource_type
        string rule
        string severity
        string title
        string description
        string recommendation
        json metadata
    }

    TerraformExecution {
        string execution_id PK
        string finding_id FK
        datetime timestamp
        string status
        string description
        text hcl
        text plan_output
        text apply_output
    }

    GeneratedFile {
        string file_id PK
        string execution_id FK
        string filename
        text content_base64
        string file_type
    }

    RagDocument {
        string doc_id PK
        string source
        string resource_type
        datetime upload_timestamp
        text content_preview
    }

    DocumentChunk {
        string chunk_id PK
        string doc_id FK
        int chunk_index
        int total_chunks
        text text
        vector embedding
        float relevance_score
    }

    ChatMessage {
        string message_id PK
        string role
        text content
        datetime timestamp
        string session_id
    }

    AwsScan ||--o{ SecurityFinding : "generates"
    SecurityFinding ||--o{ TerraformExecution : "triggers (optional)"
    TerraformExecution ||--o{ GeneratedFile : "produces"
    RagDocument ||--o{ DocumentChunk : "chunked into"
