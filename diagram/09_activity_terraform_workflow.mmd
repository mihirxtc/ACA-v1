flowchart TD
    START([User enters natural language request])

    CTX["Scan Existing Infrastructure for Context\n(VPC IDs · SG IDs · subnet IDs · IAM roles)"]

    GEN["LLM Generates Terraform HCL\n(Claude 3.5 Sonnet — context-aware prompt)"]

    VALID{{"Syntax\nValid?"}}

    INIT["Write main.tf to execution workdir\nterraform init -backend=false"]

    PLAN["terraform plan -out=tfplan\n(binary plan saved to workdir)"]

    SUMM["LLM Summarises Plan\n(converts raw terraform output to plain English)"]

    APPR{{"Human\nApproves?"}}

    APPLY["terraform apply tfplan -auto-approve\nExtract SSH keys · log to execution_log.json"]

    DONE([Applied — Available for Rollback\nExecution ID stored in history])

    REJ([Rejected\nStatus logged as 'rejected'])

    RETRY["Return syntax error to LLM\n(retry generation)"]

    START --> CTX --> GEN --> VALID
    VALID -- YES --> INIT --> PLAN --> SUMM --> APPR
    VALID -- NO --> RETRY --> GEN
    APPR -- YES --> APPLY --> DONE
    APPR -- NO --> REJ
